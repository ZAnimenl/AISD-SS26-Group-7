# Environment variable examples for local development and deployment handoff

# Frontend
# Optional. Defaults to http://localhost:5140/api/v1 in src/lib/api/index.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5140/api/v1

# Backend
# ASP.NET Core reads environment variables automatically.
# A .env file is not loaded automatically unless your shell/container tooling loads it.
ASPNETCORE_ENVIRONMENT=Development
BackendUrls=http://localhost:5140

# Local PostgreSQL connection used by the development setup.
ConnectionStrings__DefaultConnection=Host=localhost:5433;Database=ai_coding;Username=ai_coding;password=password

# Required in published/production environments because appsettings.json intentionally
# omits SeedAdmin credentials. Development also has demo values in appsettings.Development.json.
SeedAdmin__Email=admin@example.com
SeedAdmin__Password=password

# Optional OpenAI-compatible provider configuration.
# Default local demo uses LocalLlm:Enabled=false and falls back to logged mock guidance.
# For DeepSeek, set:
# LocalLlm__Enabled=true
# LocalLlm__BaseUrl=https://api.deepseek.com
# LocalLlm__Model=deepseek-chat
# LocalLlm__ApiKey=<your DeepSeek API key>
#
# DeepSeek's own docs name the key DEEPSEEK_API_KEY in examples, but the current
# ASP.NET configuration reads LocalLlm__ApiKey unless code is changed to map aliases.
# DEEPSEEK_API_KEY=
#
# Alternative hosted-provider placeholders for future dedicated adapters.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
