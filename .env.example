# Environment variable examples for local development and deployment handoff

# Frontend
# Optional for local development. Required for production frontend deployments.
# Local development defaults to http://localhost:5140/api/v1 in src/lib/api/index.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5140/api/v1

# Backend
# ASP.NET Core reads environment variables automatically.
# A .env file is not loaded automatically unless your shell/container tooling loads it.
ASPNETCORE_ENVIRONMENT=Development
BackendUrls=http://localhost:5140

# Required outside Development. Development falls back to the local PostgreSQL default if omitted.
ConnectionStrings__DefaultConnection=<real-postgresql-connection-string>

# Required for every backend run. This creates or repairs the real seed administrator.
SeedAdmin__Email=<real-admin-email>
SeedAdmin__Password=<real-initial-admin-password>

# DeepSeek AI provider (embedded AI agent).
# Store real local keys in .NET user-secrets or deployment secrets, not in tracked files.
Deepseek__ApiKey=<real-deepseek-api-key>
Deepseek__Enabled=true
# Deepseek__BaseUrl=https://api.deepseek.com
# Deepseek__Model=deepseek-v4-flash
# Deepseek__ThinkingEnabled=false
