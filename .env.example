# Environment variable examples for local development and deployment handoff

# Frontend
# Optional. Defaults to http://localhost:5040/api/v1 in src/lib/api/index.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5040/api/v1

# Backend
# ASP.NET Core reads environment variables automatically.
# A .env file is not loaded automatically unless your shell/container tooling loads it.
ASPNETCORE_ENVIRONMENT=Development
BackendUrls=http://localhost:5040

# Local PostgreSQL connection used by the development setup.
ConnectionStrings__DefaultConnection=Host=localhost:5433;Database=ai_coding;Username=ai_coding;password=password

# Required in published/production environments because appsettings.json intentionally
# omits SeedAdmin credentials. Development also has demo values in appsettings.Development.json.
SeedAdmin__Email=admin@example.com
SeedAdmin__Password=password

# Future Module 4/provider integration placeholders.
# The current backend AI chat endpoint is an MVP stub and does not read these values.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
