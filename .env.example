# Environment variable examples for local development and deployment handoff
# For local one-command startup, run npm run dev and let the script create
# .env.local. Do not put real secrets in this tracked example file.

# Frontend
# Optional for local development. Required for production frontend deployments.
# Local development defaults to http://localhost:5140/api/v1 in src/lib/api/index.ts.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5140/api/v1

# Backend
# ASP.NET Core reads environment variables automatically.
# A .env file is not loaded automatically unless your shell/container tooling loads it.
ASPNETCORE_ENVIRONMENT=Development
BackendUrls=http://localhost:5140

# Local npm run dev writes these automatically for the gitignored SQLite file.
# Deployment/external database users can set Database__Provider=PostgreSql and
# provide a real PostgreSQL connection string through deployment secrets.
Database__Provider=Sqlite
ConnectionStrings__DefaultConnection=Data Source=.local-data/ojsharp-dev.sqlite

# Optional when the sandbox runtime is Colima. Other Docker runtimes may expose
# the default /var/run/docker.sock and not need this variable.
DOCKER_HOST=unix://$HOME/.colima/default/docker.sock

# Required for every backend run. Local npm run dev uses admin@example.com and
# Admin123! when these values are missing.
SeedAdmin__Email=<real-admin-email>
SeedAdmin__Password=<real-initial-admin-password>

# Optional SMTP email delivery. These values persist through `npm run dev` in
# gitignored .env.local. Gmail requires a valid app password, not the normal
# account password. Registration still displays the code when SMTP is absent.
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__EnableSsl=true
Smtp__Username=<smtp-username>
Smtp__Password=<smtp-app-password>
Smtp__FromAddress=<verified-sender-email>
Smtp__FromName=AI-Coding Assessment Platform

# DeepSeek AI provider (embedded AI agent).
# Store real local keys in .NET user-secrets or deployment secrets, not in tracked files.
Deepseek__ApiKey=<real-deepseek-api-key>
Deepseek__Enabled=true
# Deepseek__BaseUrl=https://api.deepseek.com
# Deepseek__Model=deepseek-v4-flash
# Deepseek__ThinkingEnabled=false
